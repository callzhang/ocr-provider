SERVICE_NAME=ocr-provider
OCR_PROVIDER=tesseract
OCR_MODEL=tesseract:ch_sim+en
OCR_MODEL_ALIAS=tesseract-zh-en
API_KEY=change-me
OCR_LANGUAGES=ch_sim,en
OCR_DEVICE=cpu
OCR_PARAGRAPH=true
OCR_MODEL_STORAGE_DIR=./runtime-cache/tesseract
PDF_RENDER_SCALE=2.0
BIND_HOST=127.0.0.1
PORT=7998
TESSERACT_CMD=/opt/homebrew/bin/tesseract
